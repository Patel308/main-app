# ===========================
# SCALLAR-NEXT — .gitignore
# ===========================

# Dependencies
node_modules/
.pnp
.pnp.js

# Next.js Build Output
.next/
out/
build/
dist/

# Environment Variables (NEVER push these)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# TypeScript
*.tsbuildinfo
tsconfig.tsbuildinfo
next-env.d.ts

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Vercel
.vercel

# Debug
.pnpm-debug.log*

# Cache
.cache/
.eslintcache
.stylelintcache

# Testing
coverage/
.nyc_output/

# Misc
*.pem